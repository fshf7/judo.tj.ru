---
import Layout from "../layouts/Layout.astro";
import HeroSimple from "../components/header/HeroSimple.astro";

import aboutHero from "../assets/news/news1.jpg";

import news1 from "../assets/news/news1.jpg";
import news2 from "../assets/news/news2.jpg";
import news3 from "../assets/news/news3.jpg";
import news4 from "../assets/news/news2.jpg";
import news5 from "../assets/news/news3.jpg";
import news6 from "../assets/news/news1.jpg";
---

<Layout>
  <main>
    <HeroSimple
      background={aboutHero}
      backgroundClass="object-[0_25%]"
      title="Новости"
      description="Следите за последними событиями в мире дзюдо и нашей Федерации"
    />

    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="flex flex-wrap justify-center gap-3 mb-12">
          <button
            class="px-5 py-2 bg-gradient-to-r from-red-700 to-[#7F170D] text-white rounded-full font-medium shadow-md"
          >
            Все новости
          </button>
          <button
            class="px-5 py-2 bg-white hover:bg-gray-100 text-gray-800 rounded-full font-medium border border-gray-200 shadow-sm hover:shadow-md transition-all"
          >
            Турниры
          </button>
          <button
            class="px-5 py-2 bg-white hover:bg-gray-100 text-gray-800 rounded-full font-medium border border-gray-200 shadow-sm hover:shadow-md transition-all"
          >
            Тренировки
          </button>
          <button
            class="px-5 py-2 bg-white hover:bg-gray-100 text-gray-800 rounded-full font-medium border border-gray-200 shadow-sm hover:shadow-md transition-all"
          >
            Сборы
          </button>
          <button
            class="px-5 py-2 bg-white hover:bg-gray-100 text-gray-800 rounded-full font-medium border border-gray-200 shadow-sm hover:shadow-md transition-all"
          >
            Достижения
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news1.src}
                alt="Международный турнир по дзюдо"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-red-700 to-[#7F170D] text-white px-4 py-1 text-sm font-medium"
              >
                15 июня 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
              >
                Международный турнир в Москве
              </h3>
              <p class="text-gray-600 mb-4">
                С 20 по 22 июля в Москве пройдет международный турнир по дзюдо с участием спортсменов из 15 стран.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-red-600 hover:text-red-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>

          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news2.src}
                alt="Детская тренировка"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] text-gray-900 px-4 py-1 text-sm font-medium"
              >
                10 июня 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
              >
                Летние сборы для юных дзюдоистов
              </h3>
              <p class="text-gray-600 mb-4">
                Открыта регистрация на летние учебно-тренировочные сборы для детей 10-14 лет в Сочи.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-amber-600 hover:text-amber-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>

          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news3.src}
                alt="Сборная России"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-red-700 to-[#7F170D] text-white px-4 py-1 text-sm font-medium"
              >
                5 июня 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
              >
                Сборная России готовится к чемпионату Европы
              </h3>
              <p class="text-gray-600 mb-4">
                Национальная команда начала интенсивную подготовку к предстоящему чемпионату Европы в Будапеште.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-red-600 hover:text-red-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>

          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news4.src}
                alt="Новый зал дзюдо"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] text-gray-900 px-4 py-1 text-sm font-medium"
              >
                28 мая 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
              >
                Открытие нового додзё в Казани
              </h3>
              <p class="text-gray-600 mb-4">
                Современный зал для тренировок по дзюдо открыл свои двери для спортсменов всех возрастов.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-amber-600 hover:text-amber-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>

          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news5.src}
                alt="Чемпионат России"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-red-700 to-[#7F170D] text-white px-4 py-1 text-sm font-medium"
              >
                20 мая 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
              >
                Итоги чемпионата России
              </h3>
              <p class="text-gray-600 mb-4">
                В Екатеринбурге завершился чемпионат России по дзюдо. Все победители и призеры турнира.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-red-600 hover:text-red-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>

          <article class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="relative h-48 overflow-hidden">
              <img
                src={news6.src}
                alt="Семинар для тренеров"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div
                class="absolute bottom-0 left-0 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] text-gray-900 px-4 py-1 text-sm font-medium"
              >
                12 мая 2024
              </div>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
              >
                Семинар для тренеров
              </h3>
              <p class="text-gray-600 mb-4">
                В Москве прошел всероссийский семинар по современным методикам подготовки дзюдоистов.
              </p>
              <a
                href="#"
                class="inline-flex items-center text-amber-600 hover:text-amber-800 font-medium transition-colors"
              >
                Читать далее
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </article>
        </div>

        <div class="mt-16 flex justify-center">
          <nav class="flex items-center space-x-2">
            <button
              class="w-10 h-10 flex items-center justify-center bg-gradient-to-r from-red-700 to-[#7F170D] text-white rounded-full shadow-md"
            >
              1
            </button>
            <button
              class="w-10 h-10 flex items-center justify-center bg-white hover:bg-gray-100 text-gray-800 rounded-full border border-gray-200 shadow-sm hover:shadow-md transition-all"
            >
              2
            </button>
            <button
              class="w-10 h-10 flex items-center justify-center bg-white hover:bg-gray-100 text-gray-800 rounded-full border border-gray-200 shadow-sm hover:shadow-md transition-all"
            >
              3
            </button>
            <span class="px-2 text-gray-500">...</span>
            <button
              class="w-10 h-10 flex items-center justify-center bg-white hover:bg-gray-100 text-gray-800 rounded-full border border-gray-200 shadow-sm hover:shadow-md transition-all"
            >
              8
            </button>
            <button
              class="w-10 h-10 flex items-center justify-center bg-white hover:bg-gray-100 text-gray-800 rounded-full border border-gray-200 shadow-sm hover:shadow-md transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-6">Подпишитесь на наши новости</h2>
          <p class="text-base sm:text-lg md:text-xl opacity-90 mb-8">
            Получайте самые свежие новости о мероприятиях, турнирах и событиях Федерации дзюдо
          </p>

          <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
            <input
              type="email"
              placeholder="Ваш email"
              class="flex-grow px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#F8CB4C] text-gray-900 placeholder:text-gray-400"
              required
            />
            <button
              type="submit"
              class="px-6 py-3 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] hover:opacity-90 text-gray-900 font-bold rounded-lg shadow-md hover:shadow-lg transition-all"
            >
              Подписаться
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>
