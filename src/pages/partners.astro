---
import Layout from "../layouts/Layout.astro";
import HeroSimple from "../components/header/HeroSimple.astro";
import Sponsors from "../Sections/list/Sponsors.astro";

import partnership_1 from "../assets/pic_for_partnership_1.jpg";
import partnership_2 from "../assets/pic_for_partnership_2.png";
---

<Layout>
  <main>
    <HeroSimple
      background={partnership_1}
      backgroundClass="object-[0%_20%]"
      title="Вместе за развитие дзюдо"
      description="Поддержите будущих чемпионов вместе с нами"
    >
      <a
        href="#contact"
        class="mt-8 inline-flex items-center justify-center bg-gradient-to-r from-red-700 to-[#7F170D] hover:from-[#F8CB4C] hover:to-[#C58838] hover:opacity-90 font-semibold text-base md:text-lg py-3 px-8 rounded-md shadow-md transition-all duration-300 transform hover:-translate-y-1 text-white"
      >
        Оставить заявку
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
          <path
            fill-rule="evenodd"
            d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </HeroSimple>

    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-4"
          >
            Почему стоит сотрудничать с нами?
          </h2>
          <p class="text-gray-600">Мы развиваем дзюдо, воспитываем чемпионов и меняем жизни спортсменов</p>
          <div class="w-24 h-1 bg-gradient-to-r from-red-700 to-[#7F170D] mx-auto mt-6"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-8 md:gap-12">
          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 5H19V11"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 5L5 19"></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Развитие спорта
            </h3>
            <p class="text-gray-600">Вы становитесь частью большого пути — от тренировок до международных побед.</p>
          </div>
          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="m11 17 2 2a1 1 0 1 0 3-3"></path><path
                  d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"
                ></path><path d="m21 3 1 11h-2"></path><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"></path><path d="M3 4h8"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Социальная ответственность
            </h3>
            <p class="text-gray-600">
              Ваша поддержка помогает детям из малообеспеченных семей пробить путь в большой спорт.
            </p>
          </div>
          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M5.8 11.3 2 22l10.7-3.79"></path><path d="M4 3h.01"></path><path d="M22 8h.01"></path><path
                  d="M15 2h.01"></path><path d="M22 20h.01"></path><path
                  d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"
                ></path><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11c-.11.7-.72 1.22-1.43 1.22H17"></path><path
                  d="m11 2 .33.82c.34.86-.2 1.82-1.11 1.98C9.52 4.9 9 5.52 9 6.23V7"></path><path
                  d="M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-semibold mb-3 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Видимый результат
            </h3>
            <p class="text-gray-600">Вы видите, как ваши инвестиции превращаются в победы, медали и новые таланты.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white relative overflow-hidden">
      <!-- <div
        class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-red-50 to-transparent opacity-20 blur-3xl"
      > -->
      <div class="container mx-auto px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-12 items-center">
          <div class="lg:w-1/2">
            <img src={partnership_2.src} alt="Тренировка борцов" class="rounded-xl shadow-lg w-full object-cover" />
          </div>
          <div class="lg:w-1/2">
            <h2
              class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-4"
            >
              Как мы работаем с партнёрами
            </h2>
            <div class="flex justify-center md:justify-start">
              <ul class="max-w-full sm:max-w-[80%] md:max-w-full space-y-4 text-[#666666] text-base lg:text-lg">
                <li class="grid grid-cols-12 items-center gap-4">
                  <svg class="w-[24px] h-[24px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <defs>
                      <linearGradient id="checkGradient" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#C58838"></stop>
                        <stop offset="100%" stop-color="#F8CB4C"></stop>
                      </linearGradient>
                    </defs>
                    <path
                      fill="url(#checkGradient)"
                      d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z"></path>
                  </svg>

                  <div class="col-span-10">Создаём программу взаимодействия с учетом вашего бренда и целей</div>
                </li>
                <li class="grid grid-cols-12 items-center gap-4">
                  <svg class="w-[24px] h-[24px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <defs>
                      <linearGradient id="checkGradient" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#C58838"></stop>
                        <stop offset="100%" stop-color="#F8CB4C"></stop>
                      </linearGradient>
                    </defs>
                    <path
                      fill="url(#checkGradient)"
                      d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z"></path>
                  </svg>
                  <div class="col-span-10">
                    Определяем цели и формат участия (спонсорство, грант, инфраструктурная помощь)
                  </div>
                </li>
                <li class="grid grid-cols-12 items-center gap-4">
                  <svg class="w-[24px] h-[24px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                    ><defs>
                      <linearGradient id="checkGradient" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#C58838"></stop>
                        <stop offset="100%" stop-color="#F8CB4C"></stop>
                      </linearGradient>
                    </defs>
                    <path
                      fill="url(#checkGradient)"
                      d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z"></path>
                  </svg>
                  <div class="col-span-10">Регулярные отчеты и презентации о результатах использования средств</div>
                </li>
                <li class="grid grid-cols-12 items-center gap-4">
                  <svg class="w-[24px] h-[24px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                    ><defs>
                      <linearGradient id="checkGradient" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#C58838"></stop>
                        <stop offset="100%" stop-color="#F8CB4C"></stop>
                      </linearGradient>
                    </defs>
                    <path
                      fill="url(#checkGradient)"
                      d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z"></path>
                  </svg>
                  <div class="col-span-10">Участие в мероприятиях, брендирование, медиа-покрытие</div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-4"
        >
          Что вы получите, став нашим партнером
        </h2>
        <p class="text-gray-600">Программа сотрудничества создана с учетом интересов бизнеса и развития спорта</p>
        <div class="w-24 h-1 bg-gradient-to-r from-red-700 to-[#7F170D] mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start gap-4">
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-red-100 to-yellow-100 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-headset-icon lucide-headset"
              ><path
                d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"
              ></path><path d="M21 16v2a4 4 0 0 1-4 4h-5"></path></svg
            >
          </div>
          <div>
            <h3 class="font-semibold text-lg text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">
              Реклама и PR
            </h3>
            <p class="text-gray-600">Публикация вашей компании на нашем сайте, в СМИ и на мероприятиях</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-red-100 to-yellow-100 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-globe-icon lucide-globe"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"
              ></path><path d="M2 12h20"></path></svg
            >
          </div>
          <div>
            <h3 class="font-semibold text-lg text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">
              Национальное и международное представительство
            </h3>
            <p class="text-gray-600">Ваш бренд будет ассоциироваться с развитием спорта и поддержкой молодежи</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-red-100 to-yellow-100 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-person-standing-icon lucide-person-standing"
              ><circle cx="12" cy="5" r="1"></circle><path d="m9 20 3-6 3 6"></path><path d="m6 8 6 2 6-2"></path><path
                d="M12 10v4"></path></svg
            >
          </div>
          <div>
            <h3 class="font-semibold text-lg text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">
              Индивидуальный подход
            </h3>
            <p class="text-gray-600">Разрабатываем уникальные решения под запросы вашего бизнеса</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-red-100 to-yellow-100 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-shield-check-icon lucide-shield-check"
              ><path
                d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
              ></path><path d="m9 12 2 2 4-4"></path></svg
            >
          </div>
          <div>
            <h3 class="font-semibold text-lg text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">
              Сертификаты и благодарности
            </h3>
            <p class="text-gray-600">Вы получаете официальные документы, подтверждающие ваше участие в проектах</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="py-12 md:py-20 lg:py-12">
        <Sponsors />
    </div>
  </section>

  <section id="contact" class="py-20 bg-white relative overflow-hidden">
    <div
      class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-gradient-to-l from-red-100 to-yellow-100 opacity-20 blur-3xl z-0"
    >
    </div>
    <div class="container mx-auto px-6 lg:px-8 relative z-10">
      <div
        class="bg-gradient-to-r from-red-700 to-[#7F170D] rounded-2xl shadow-lg px-5 py-8 md:px-10 md:py-10 text-center text-white"
      >
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold mb-6">Хотите стать частью спортивной истории?</h2>
        <p class="text-base md:text-xl mb-8 opacity-90">Заполните форму ниже, и мы свяжемся с вами в ближайшие часы.</p>
        <form action="/actions/send-email" method="post" class="max-w-xl mx-auto space-y-4">
          <input
            type="text"
            placeholder="Ваше имя"
            name="name"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500"
          />
          <input
            type="tel"
            placeholder="Телефон"
            name="phone"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500"
          />
          <input
            type="email"
            placeholder="Email"
            name="email"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500"
          />
          <button
            type="submit"
            class="inline-block bg-white text-red-700 hover:bg-red-50 px-8 py-3 rounded-lg font-semibold shadow-md transition-all duration-300 transform hover:-translate-y-1"
          >
            Отправить заявку
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
