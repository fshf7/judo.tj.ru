---
import Layout from "../layouts/Layout.astro";
import HeroSimple from "../components/header/HeroSimple.astro";

import Olymp from "../assets/sections/fund/img9.png";

import Coins from "../assets/icons/coins.svg";
---

<Layout>
  <main>
    <HeroSimple
      background={Olymp}
      backgroundClass="object-center"
      title="Фонд поддержки дзюдо"
      description="Помогаем развивать дзюдо в России и поддерживаем молодых спортсменов"
    >
      <a
        href="#donate"
        class="mt-8 inline-flex items-center justify-center bg-gradient-to-r from-red-700 to-[#7F170D] hover:from-[#F8CB4C] hover:to-[#C58838] hover:opacity-90 text-white font-semibold text-base md:text-lg py-3 px-8 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1"
      >
        Поддержать фонд
      </a>
    </HeroSimple>

    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-center gap-12">
          <div class="lg:w-1/2">
            <div class="relative group overflow-hidden rounded-2xl shadow-2xl h-96">
              <img
                src={Olymp.src}
                alt=""
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
            </div>
          </div>
          <div class="lg:w-1/2">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-6">
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">О нашем фонде</span
              >
            </h2>
            <p class="text-base sm:text-lg md:text-xl text-gray-600 mb-6">
              Фонд поддержки дзюдо создан для развития этого вида спорта в России. Мы помогаем молодым талантливым
              спортсменам, поддерживаем тренеров и организуем турниры.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start">
                <div
                  class="flex-shrink-0 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full p-2 mr-4 stroke-black"
                >
                  <div style="width: 24px;">
                    <Coins />
                  </div>
                </div>
                <p class="text-gray-700">Финансовая поддержка перспективных спортсменов</p>
              </li>
              <li class="flex items-start">
                <div class="flex-shrink-0 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full p-2 mr-4">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-notebook-pen-icon lucide-notebook-pen"
                    ><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"></path><path d="M2 6h4"
                    ></path><path d="M2 10h4"></path><path d="M2 14h4"></path><path d="M2 18h4"></path><path
                      d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"
                    ></path></svg
                  >
                </div>
                <p class="text-gray-700">Организация турниров и тренировочных сборов</p>
              </li>
              <li class="flex items-start">
                <div class="flex-shrink-0 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full p-2 mr-4">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-arrow-big-up-icon lucide-arrow-big-up"
                    ><path d="M9 18v-6H5l7-7 7 7h-4v6H9z"></path></svg
                  >
                </div>
                <p class="text-gray-700">Развитие детского и юношеского дзюдо</p>
              </li>
            </ul>
            <a
              href="#mission"
              class="inline-flex items-center text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] font-medium hover:opacity-80 transition-opacity"
            >
              Узнать больше о нашей миссии
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="donate" class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-12">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-6"
          >
            Поддержите развитие дзюдо
          </h2>
          <p class="text-base md:text-xl text-gray-600">
            Ваши пожертвования помогают молодым спортсменам достигать высот
          </p>
        </div>

        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-lg p-8 md:p-10">
          <div class="mb-8">
            <div class="flex justify-between mb-2">
              <span class="text-sm font-medium text-gray-700">Собрано: 1,240,500 ₽</span>
              <span class="text-sm font-medium text-gray-700">Цель: 2,000,000 ₽</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-4">
              <div class="bg-gradient-to-r from-red-700 to-[#7F170D] h-4 rounded-full" style="width: 62%"></div>
            </div>
          </div>

          <form class="space-y-6">
            <div>
              <label for="amount" class="block text-base md:text-lg font-medium text-gray-700 mb-2"
                >Сумма пожертвования</label
              >
              <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <button
                  type="button"
                  class="py-3 px-4 border border-gray-300 rounded-lg font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-colors"
                >
                  500 ₽
                </button>
                <button
                  type="button"
                  class="py-3 px-4 border border-gray-300 rounded-lg font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-colors"
                >
                  1 000 ₽
                </button>
                <button
                  type="button"
                  class="py-3 px-4 border border-gray-300 rounded-lg font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-colors"
                >
                  2 000 ₽
                </button>
                <button
                  type="button"
                  class="py-3 px-4 border border-gray-300 rounded-lg font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-colors"
                >
                  Другая
                </button>
              </div>
            </div>

            <div>
              <label for="custom-amount" class="block text-base md:text-lg font-medium text-gray-700 mb-2"
                >Или введите свою сумму</label
              >
              <input
                type="number"
                id="custom-amount"
                placeholder="Сумма в рублях"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent text-base md:text-lg"
              />
            </div>

            <div>
              <label for="name" class="block text-base md:text-lg font-medium text-gray-700 mb-2">Ваше имя</label>
              <input
                type="text"
                id="name"
                placeholder="Как к вам обращаться?"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent text-base md:text-lg"
              />
            </div>

            <div>
              <label for="email" class="block text-base md:text-lg font-medium text-gray-700 mb-2">Email</label>
              <input
                type="email"
                id="email"
                placeholder="Для отправки квитанции"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent text-base md:text-lg"
              />
            </div>

            <button
              type="submit"
              class="w-full py-4 px-6 bg-gradient-to-r from-red-700 to-[#7F170D] hover:from-[#F8CB4C] hover:to-[#C58838] hover:opacity-90 text-white font-semibold text-base md:text-lg rounded-lg shadow-md hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1"
            >
              Поддержать фонд
            </button>

            <p class="text-sm text-gray-500 text-center">
              Нажимая кнопку, вы соглашаетесь с <a href="#" class="text-red-600 hover:underline"
                >условиями обработки данных</a
              >
            </p>
          </form>
        </div>
      </div>
    </section>

    <section id="mission" class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-6"
          >
            Наша миссия
          </h2>
          <div class="w-24 h-1 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] mx-auto"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8 md:gap-12">
          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6 mx-auto"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-heart-handshake-icon lucide-heart-handshake"
                ><path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                ></path><path
                  d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"
                ></path><path d="m18 15-2-2"></path><path d="m15 18-2-2"></path></svg
              >
            </div>
            <h3
              class="text-lg md:text-xl font-semibold mb-3 text-center text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Поддержка спортсменов
            </h3>
            <p class="text-gray-600 text-center">
              Финансирование тренировок, сборов и участия в соревнованиях для талантливых дзюдоистов
            </p>
          </div>

          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6 mx-auto"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-building-icon lucide-building"
                ><rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path
                  d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"
                ></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path
                  d="M8 10h.01"></path><path d="M8 14h.01"></path></svg
              >
            </div>
            <h3
              class="text-lg md:text-xl font-semibold mb-3 text-center text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Развитие инфраструктуры
            </h3>
            <p class="text-gray-600 text-center">Создание и модернизация додзё, залов для тренировок по всей стране</p>
          </div>

          <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition-shadow">
            <div
              class="w-14 h-14 bg-gradient-to-r from-red-100 to-[#F8CB4C]/20 rounded-full flex items-center justify-center mb-6 mx-auto"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-graduation-cap-icon lucide-graduation-cap"
                ><path
                  d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"
                ></path><path d="M22 10v6"></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path></svg
              >
            </div>
            <h3
              class="text-lg md:text-xl font-semibold mb-3 text-center text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
            >
              Образовательные программы
            </h3>
            <p class="text-gray-600 text-center">Подготовка тренеров, судей и организация обучающих семинаров</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-12">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-6"
          >
            Истории успеха
          </h2>
          <p class="text-lg md:text-xl text-gray-600">Спортсмены, которым помог наш фонд</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-r from-red-700 to-[#7F170D] flex items-center justify-center">
              <svg class="h-20 w-20 text-white opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
              >
                Иван Петров
              </h3>
              <p class="text-gray-600 mb-4">Чемпион России среди юниоров</p>
              <p class="text-gray-700">
                "Благодаря поддержке фонда смог поехать на международные соревнования, где занял призовое место"
              </p>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-r from-[#F8CB4C] to-[#C58838] flex items-center justify-center">
              <svg class="h-20 w-20 text-white opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
              >
                Анна Сидорова
              </h3>
              <p class="text-gray-600 mb-4">Призер Европейского первенства</p>
              <p class="text-gray-700">"Фонд помог с оплатой тренировочного лагеря перед важными соревнованиями"</p>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-r from-red-700 to-[#7F170D] flex items-center justify-center">
              <svg class="h-20 w-20 text-white opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-2 text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]"
              >
                Дмитрий Иванов
              </h3>
              <p class="text-gray-600 mb-4">Тренер детской команды</p>
              <p class="text-gray-700">
                "Благодаря фонду мы смогли оборудовать зал для тренировок детей в нашем городе"
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container mx-auto px-6 lg:px-8 text-center">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838] mb-6"
        >
          Каждый рубль - это шаг к победе
        </h2>
        <p class="text-lg md:text-xl opacity-90 mb-8 max-w-2xl mx-auto">
          Ваша поддержка помогает растить новых чемпионов и развивать дзюдо в России
        </p>
        <a
          href="#donate"
          class="inline-flex items-center justify-center bg-gradient-to-r from-[#F8CB4C] to-[#C58838] hover:opacity-90 text-gray-900 font-bold text-lg py-4 px-12 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1"
        >
          Поддержать фонд
        </a>
      </div>
    </section>
  </main>
</Layout>
