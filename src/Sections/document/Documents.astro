---
import doc1 from "../../assets/sections/decree/main.png";
import doc2 from "../../assets/sections/decree/perevod.JPG";
import doc3 from "../../assets/sections/decree/doverenost.png";
---

<section class="bg-[#181d28] py-12 px-4 text-white">
  <div class="max-w-[1240px] mx-auto text-center mb-10">
    <h2
      class="text-2xl sm:text-3xl md:text-4xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
    >
      Основополагающие документы
    </h2>
    <div
      class="w-24 h-1 bg-gradient-to-r from-[#C58838] to-[#F8CB4C] mx-auto rounded-full mt-4"
    >
    </div>
  </div>


  <div
    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 max-w-[1240px] mx-auto"
  >
    <!-- Документ 1 -->
    <div
      class="bg-gradient-to-r from-[#F8CB4C] to-[#C58838] p-[3px] rounded-lg shadow-lg hover:scale-[1.02] transition-transform duration-300"
    >
      <div class="bg-[#181d28] rounded-lg overflow-hidden h-full flex flex-col">
        <img src={doc1.src} alt="Документ 1" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Документ 2 -->
    <div
      class="bg-gradient-to-r from-[#F8CB4C] to-[#C58838] p-[3px] rounded-lg shadow-lg hover:scale-[1.02] transition-transform duration-300"
    >
      <div class="bg-[#181d28] rounded-lg overflow-hidden h-full flex flex-col">
        <img src={doc2.src} alt="Документ 2" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Документ 3 -->
    <div
      class="bg-gradient-to-r from-[#F8CB4C] to-[#C58838] p-[3px] rounded-lg shadow-lg hover:scale-[1.02] transition-transform duration-300"
    >
      <div class="bg-[#181d28] rounded-lg overflow-hidden h-full flex flex-col">
        <img src={doc3.src} alt="Документ 3" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>
