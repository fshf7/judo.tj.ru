---
import PopupHeader from "../../components/modal/PopupHeader.astro";

import image from "../../assets/components/popup/home.png";
---

<PopupHeader image={image}>
  <h2 class="text-2xl font-bold text-center mb-3">
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D]">
      Специальное предложение
    </span>
  </h2>

  <p class="text-gray-700 text-center mb-5">
    Подпишитесь на нашу рассылку и получите эксклюзивный доступ к материалам для тренировок
  </p>
  <div class="mb-4">
    <input
      type="email"
      placeholder="Ваш email"
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
    />
  </div>
  <div class="flex flex-col space-y-3">
    <button
      class="bg-gradient-to-r from-red-700 to-[#7F170D] hover:opacity-90 text-white font-semibold py-3 px-4 rounded-lg shadow-md transition-opacity"
    >
      Подписаться сейчас
    </button>
    <button id="laterButton" class="text-gray-600 hover:text-gray-800 text-sm font-medium py-2 transition-colors">
      Напомнить позже
    </button>
  </div>
</PopupHeader>
