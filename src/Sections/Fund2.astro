---
import img1 from "../assets/sections/fund/img1.jpg";
import img2 from "../assets/sections/fund/img2.jpg";
import img3 from "../assets/sections/fund/img3.jpg";
import img4 from "../assets/sections/fund/img4.png";
import img5 from "../assets/sections/fund/img5.png";
import img6 from "../assets/sections/fund/img6.png";
import img7 from "../assets/sections/fund/img7.png";
import img8 from "../assets/sections/fund/img8.png";
import img9 from "../assets/sections/fund/img9.png";
import img10 from "../assets/sections/fund/img10.png";
import img11 from "../assets/sections/fund/img11.png";
import img12 from "../assets/sections/fund/img12.png";
import img13 from "../assets/sections/fund/img13.png";
import img14 from "../assets/sections/fund/img14.png";
import img15 from "../assets/sections/fund/img15.png";

import Coins from "../assets/icons/coins.svg";
import Transparent from "../assets/icons/square-dashed.svg";
import Clipboard from "../assets/icons/clipboard.svg";

const images = [
  img1,
  img2,
  img3,
  img4,
  img5,
  img6,
  img7,
  img8,
  img9,
  img10,
  img11,
  img12,
  img13,
  img14,
  img15,
];
---

<section class="relative w-full py-12 px-4 overflow-hidden">
  <!-- xs: 6 фото (2x3) -->
  <div class="absolute inset-0 z-0 grid grid-cols-2 grid-rows-3 sm:hidden">
    {
      images.slice(0, 6).map((img, i) => (
        <div class="overflow-hidden">
          <img
            src={img.src}
            alt={`фон-xs-${i}`}
            class="w-full h-full object-cover"
          />
        </div>
      ))
    }
  </div>

  <!-- sm: 9 фото (3x3) -->
  <div
    class="absolute inset-0 z-0 hidden sm:grid md:hidden grid-cols-3 grid-rows-3"
  >
    {
      images.slice(0, 9).map((img, i) => (
        <div class="overflow-hidden">
          <img
            src={img.src}
            alt={`фон-sm-${i}`}
            class="w-full h-full object-cover"
          />
        </div>
      ))
    }
  </div>

  <!-- md: 12 фото (4x3) -->
  <div
    class="absolute inset-0 z-0 hidden md:grid lg:hidden grid-cols-4 grid-rows-3"
  >
    {
      images.slice(0, 12).map((img, i) => (
        <div class="overflow-hidden">
          <img
            src={img.src}
            alt={`фон-md-${i}`}
            class="w-full h-full object-cover"
          />
        </div>
      ))
    }
  </div>

  <!-- lg+: 15 фото (5x3) -->
  <div class="absolute inset-0 z-0 hidden lg:grid grid-cols-5 grid-rows-3">
    {
      images.slice(0, 15).map((img, i) => (
        <div class="overflow-hidden">
          <img
            src={img.src}
            alt={`фон-lg-${i}`}
            class="w-full h-full object-cover"
          />
        </div>
      ))
    }
  </div>

  <!-- Затемнение поверх фона -->
  <div class="absolute inset-0 bg-black/65 z-10"></div>

  <!-- Контент по центру -->
  <div class="relative z-20 max-w-[900px] mx-auto">
    <div class="text-left text-white animate-fade-in-up">
      <h3
        class="text-xl md:text-3xl font-semibold text-transparent bg-clip-text bg-gradient-to-l from-[#F8CB4C] to-[#C58838] mb-8 leading-tight"
      >
        ФОНД ПОДДЕРЖКИ РОССИЙСКОГО И ТАДЖИКСКОГО ДЗЮДО
      </h3>

      <div class="space-y-6 mb-10">
        <div class="flex items-start gap-4 max-w-xl mx-auto md:mx-0 group">
          <div
            class="mt-1 transform group-hover:scale-110 transition-transform"
            style="stroke: #C58838; width: 30px;"
          >
            <Transparent />
          </div>
          <div>
            <h4
              class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
            >
              Полностью прозрачный фонд
            </h4>
            <p class="text-gray-300 text-sm mt-1">
              Все финансовые операции открыты для проверки
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4 max-w-xl mx-auto md:mx-0 group">
          <div
            class="mt-1 transform group-hover:scale-110 transition-transform"
            style="stroke: #C58838; width: 30px;"
          >
            <Coins />
          </div>
          <div>
            <h4
              class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
            >
              Любые способы оплаты
            </h4>
            <p class="text-gray-300 text-sm mt-1">
              Банковские карты, электронные кошельки, криптовалюта
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4 max-w-xl mx-auto md:mx-0 group">
          <div
            class="mt-1 transform group-hover:scale-110 transition-transform"
            style="stroke: #C58838; width: 30px;"
          >
            <Clipboard />
          </div>
          <div>
            <h4
              class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838]"
            >
              Рейтинговая система
            </h4>
            <p class="text-gray-300 text-sm mt-1">
              Отслеживайте свой вклад в развитие дзюдо
            </p>
          </div>
        </div>
      </div>

      <p
        class="text-gray-300 text-base md:text-lg leading-relaxed mb-8 max-w-2xl mx-auto md:mx-0"
      >
        Создаём сильное спортивное сообщество вместе! Фонд поддерживает молодых
        талантов, организует соревнования и укрепляет дружбу между народами
        через дзюдо.
      </p>

      <div class="text-left">
        <a
          href="fund"
          class="inline-block bg-gradient-to-l from-[#F8CB4C] to-[#C58838] hover:from-red-700 hover:to-[#7F170D] text-white font-semibold py-3 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-md hover:shadow-lg"
        >
          Поддержать фонд
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 inline-block ml-2 -mr-1"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
  }
</style>
