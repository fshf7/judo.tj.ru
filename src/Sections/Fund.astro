---
import fund from "../assets/sections/fund/fund.jpg";

import Coins from "../assets/icons/coins.svg";
import Transparent from "../assets/icons/square-dashed.svg";
import Clipboard from "../assets/icons/clipboard.svg";
---

<section class="py-16 md:py-24" id="support-fund">
  <div class="container mx-auto px-4">
    <div
      class="flex flex-col lg:flex-row rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-shadow duration-300"
    >
      <div class="w-full lg:w-1/2 relative">
        <img
          decoding="async"
          class="w-full h-full object-cover min-h-[300px] lg:min-h-[400px]"
          src={fund.src}
          alt="Judo athletes"
          data-aos="fade-right"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>

      <div class="w-full lg:w-1/2 p-8 md:p-12 flex flex-col justify-center" data-aos="fade-left">
        <h3
          class="text-xl md:text-3xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-700 to-[#7F170D] mb-6 text-center lg:text-left leading-tight"
        >
          ФОНД ПОДДЕРЖКИ РОССИЙСКОГО И ТАДЖИКСКОГО ДЗЮДО
        </h3>

        <div class="space-y-6 mb-8">
          <div class="flex items-start group">
            <div
              class="mr-4 mt-1 transform group-hover:scale-110 transition-transform"
              style="stroke: #C58838; width: 35px;"
            >
              <Transparent />
            </div>
            <div>
              <h4
                class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838] group-hover:text-[#C58838] transition-colors"
              >
                Полностью прозрачный фонд
              </h4>
              <p class="text-gray-600 mt-1">Все финансовые операции открыты для проверки</p>
            </div>
          </div>

          <div class="flex items-start group">
            <div
              class="mr-4 mt-1 transform group-hover:scale-110 transition-transform"
              style="stroke: #C58838; width: 35px;"
            >
              <Coins />
            </div>
            <div>
              <h4
                class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838] group-hover:text-[#C58838] transition-colors"
              >
                Любые способы оплаты
              </h4>
              <p class="text-gray-600 mt-1">Банковские карты, электронные кошельки, криптовалюта</p>
            </div>
          </div>

          <div class="flex items-start group">
            <div
              class="mr-4 mt-1 transform group-hover:scale-110 transition-transform"
              style="stroke: #C58838; width: 35px;"
            >
              <Clipboard />
            </div>
            <div>
              <h4
                class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#F8CB4C] to-[#C58838] group-hover:text-[#C58838] transition-colors"
              >
                Рейтинговая система
              </h4>
              <p class="text-gray-600 mt-1">Отслеживайте свой вклад в развитие дзюдо</p>
            </div>
          </div>
        </div>

        <p class="text-gray-700 mb-8 text-base md:text-lg leading-relaxed text-center lg:text-left">
          Создаём сильное спортивное сообщество вместе! Фонд поддерживает молодых талантов, организует соревнования и
          укрепляет дружбу между народами через дзюдо.
        </p>

        <div class="text-center lg:text-left">
          <a
            href="fund"
            class="inline-block bg-gradient-to-r from-[#F8CB4C] to-[#C58838] hover:from-red-700 hover:to-[#7F170D] text-white font-semibold py-3 px-8 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-md hover:shadow-lg"
          >
            Поддержать фонд
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 inline-block ml-2 -mr-1"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
