---
import logo from "../assets/utils/logo.png";

import Instagram from "../assets/icons/social/ig.svg";
import Telegram from "../assets/icons/social/tg.svg";
import Youtube from "../assets/icons/social/yt.svg";
---

<footer class="bg-[#050505] text-white py-8">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row gap-8 md:gap-4">
      <div class="md:w-1/3 lg:w-2/5 text-center md:text-start">
        <div class="flex flex-col space-y-6">
          <h3 class="text-xl font-semibold mb-2">Контакты</h3>

          <a
            href="tel:+79269088695"
            class="flex items-start md:justify-start justify-center hover:text-[#db545a] transition-colors duration-200 group"
          >
            <svg
              class="w-5 h-5 mt-0.5 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <span>+7 (926) 908-86-95</span>
          </a>

          <a
            href="mailto:mail@mail.ru"
            class="flex items-start md:justify-start justify-center hover:text-[#db545a] transition-colors duration-200 group"
          >
            <svg
              class="w-5 h-5 mt-0.5 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <span>tjkjudoinmoscow@mail.ru</span>
          </a>

          <div class="flex items-start md:justify-start justify-center">
            <svg
              class="w-5 h-5 mt-0.5 mr-3 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
            <div>
              <p>Байкальская улица, 35А</p>
              <p>Москва, 107207</p>
            </div>
          </div>
        </div>
      </div>

      <div class="md:w-1/4 lg:w-1/5 flex items-center justify-center">
        <a href="#" class="block hover:opacity-90 transition-opacity duration-200">
          <img src={logo.src} alt="Logo" class="h-20 w-auto" />
        </a>
      </div>

      <div class="md:w-5/12 lg:w-2/5">
        <div class="flex flex-col items-center md:items-end h-full">
          <h3 class="text-xl font-semibold mb-4">Подписывайтесь на нас</h3>
          <div class="flex space-x-6">
            <a
              href="#"
              target="_blank"
              class="stroke-white hover:stroke-[#54a5db] transition-colors duration-200 w-[36px]"
            >
              <Telegram />
            </a>

            <a
              href="#"
              target="_blank"
              class="stroke-white hover:stroke-[#db545a] transition-colors duration-200 w-[36px]"
            >
              <Youtube />
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-gray-700 text-center text-gray-400 text-sm">
      <p>© {new Date().getFullYear()} TJF. Все права защищены.</p>
    </div>
  </div>
</footer>
